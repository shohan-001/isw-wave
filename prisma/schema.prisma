// ISW Wave — Prisma schema (Phase 5: multi-tenancy)
// LibSQL adapter: local SQLite in dev, Turso in production (see src/lib/db.ts).
//
// Phase 5: Organization owns Events; organizers sign up and create multiple
// isolated events (slug URLs). Phase 2–4 auth/features unchanged per event.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Organizer account — one org per owner (MVP). Phase 6 may add team members.
model Organization {
  id      String @id @default(cuid())
  name    String
  ownerId String @unique
  owner   User   @relation("OrgOwner", fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[] @relation("OrgEvents")
}

model Event {
  id   String @id @default(cuid())
  name String

  // Public URL: /e/{slug}
  slug String @unique

  accessCode String @unique

  organizationId String
  organization   Organization @relation("OrgEvents", fields: [organizationId], references: [id])

  // Legacy: creating admin user (same as org owner for migrated rows).
  adminId String
  admin   User   @relation("EventAdmin", fields: [adminId], references: [id])

  requestLimit Int    @default(3)
  approvalMode String @default("manual")

  maxSongSeconds  Int    @default(480)
  blockedKeywords String @default("")
  autoModMode     String @default("reject")

  accentColor String @default("#e0338f")
  logoUrl     String @default("")
  displayMode String @default("full")

  currentRequestId String? @unique
  // When the queue is empty, admin may loop FallbackTrack — mirror that on display.
  currentFallbackId String @default("")

  // Hall display timeline — last known YouTube position from admin player.
  playbackPositionSec Float    @default(0)
  playbackPlaying     Boolean  @default(false)
  playbackUpdatedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants   Participant[]   @relation("EventParticipants")
  requests       Request[]       @relation("EventRequests")
  fallbackTracks FallbackTrack[] @relation("EventFallback")
  current        Request?        @relation("CurrentlyPlaying", fields: [currentRequestId], references: [id])

  @@index([adminId])
  @@index([organizationId])
}

model User {
  id           String  @id @default(cuid())
  username     String  @unique
  email        String  @unique
  passwordHash String
  isAdmin      Boolean @default(true)

  createdAt DateTime @default(now())

  organization Organization? @relation("OrgOwner")
  events       Event[]       @relation("EventAdmin")
}

model Participant {
  id          String @id @default(cuid())
  eventId     String
  displayName String
  deviceId    String

  createdAt DateTime @default(now())

  event    Event     @relation("EventParticipants", fields: [eventId], references: [id])
  requests Request[] @relation("ParticipantRequests")
  votes    Vote[]    @relation("ParticipantVotes")

  @@unique([eventId, deviceId])
  @@index([deviceId])
  @@index([eventId])
}

model Request {
  id              String @id @default(cuid())
  eventId         String
  youtubeVideoId  String
  title           String
  thumbnailUrl    String
  durationSeconds Int
  channelName     String @default("")

  participantId String
  requesterName String

  status String @default("pending")

  queuePosition Int?
  voteCount     Int     @default(0)
  flagged       Boolean @default(false)
  flagReason    String  @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event         Event       @relation("EventRequests", fields: [eventId], references: [id])
  participant   Participant @relation("ParticipantRequests", fields: [participantId], references: [id])
  votes         Vote[]      @relation("RequestVotes")
  nowPlayingFor Event?      @relation("CurrentlyPlaying")

  @@index([eventId, status])
  @@index([participantId])
  @@index([eventId, voteCount])
}

model Vote {
  id            String @id @default(cuid())
  requestId     String
  participantId String

  createdAt DateTime @default(now())

  request     Request     @relation("RequestVotes", fields: [requestId], references: [id], onDelete: Cascade)
  participant Participant @relation("ParticipantVotes", fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([requestId, participantId])
  @@index([requestId])
}

model FallbackTrack {
  id              String @id @default(cuid())
  eventId         String
  youtubeVideoId  String
  title           String
  thumbnailUrl    String
  durationSeconds Int    @default(0)
  channelName     String @default("")
  position        Int

  createdAt DateTime @default(now())

  event Event @relation("EventFallback", fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, position])
}

// Phase 5 — YouTube search cache (shared across events, 15 min TTL).
model SearchCache {
  id        String   @id @default(cuid())
  queryKey  String   @unique
  results   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// Daily YouTube API quota counter (search.list = 100 units, videos.list = 1).
model YouTubeQuotaDay {
  dayKey    String @id
  unitsUsed Int    @default(0)
  updatedAt DateTime @updatedAt
}
