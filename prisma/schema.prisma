// ISW Wave — Prisma schema (Phase 2: event-code join)
// Uses the LibSQL driver adapter: a plain local SQLite file in dev, and a
 // hosted Turso/LibSQL instance in production (see src/lib/db.ts).
//
// Phase 2 auth model:
// - Admins: User accounts (email/username + password). Each admin owns Event(s).
// - Attendees: Participant rows — join with display name + Event.accessCode.
 //   No email/password. A deviceId locks a phone to one display name forever.
 // - Multiple events can run at once (each has its own accessCode + queue).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id   String @id @default(cuid())
  name String

  // Short code attendees type (or scan via QR) to join this event.
  // Unique so two simultaneous events never collide.
  accessCode String @unique

  // Owning admin. Required for multi-event: each control room scopes to its
  // admin's event(s). Phase 5 can add multi-admin / invite flows later.
  adminId String
  admin   User   @relation("EventAdmin", fields: [adminId], references: [id])

  // --- Settings live directly on the Event ---
  requestLimit Int    @default(3) // max pending/queued requests per participant
  approvalMode String @default("manual") // "manual" | "auto"

  // Which request is currently playing on the admin (audio) player.
  currentRequestId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants Participant[] @relation("EventParticipants")
  requests     Request[]     @relation("EventRequests")
  current      Request?      @relation("CurrentlyPlaying", fields: [currentRequestId], references: [id])

  @@index([adminId])
}

// Admin accounts only. Attendees never get a User row — they join as Participant.
model User {
  id           String  @id @default(cuid())
  username     String  @unique
  email        String  @unique
  passwordHash String
  isAdmin      Boolean @default(true)

  createdAt DateTime @default(now())

  events Event[] @relation("EventAdmin")
}

// An attendee joined to a specific event. deviceId is a client-generated UUID
 // stored in localStorage. Once a device has used a display name anywhere, that
 // name is locked for the device (enforced in /api/auth/join).
model Participant {
  id          String @id @default(cuid())
  eventId     String
  displayName String
  deviceId    String

  createdAt DateTime @default(now())

  event    Event     @relation("EventParticipants", fields: [eventId], references: [id])
  requests Request[] @relation("ParticipantRequests")

  // One join per device per event (re-join restores the same participant).
  @@unique([eventId, deviceId])
  @@index([deviceId])
  @@index([eventId])
}

model Request {
  id              String @id @default(cuid())
  eventId         String
  youtubeVideoId  String
  title           String
  thumbnailUrl    String
  durationSeconds Int
  channelName     String @default("")

  participantId String
  requesterName String

  // pending | approved | rejected | played
  status String @default("pending")

  // Order within the approved queue. Null unless status = approved.
  queuePosition Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event       Event       @relation("EventRequests", fields: [eventId], references: [id])
  participant Participant @relation("ParticipantRequests", fields: [participantId], references: [id])
  nowPlayingFor Event?    @relation("CurrentlyPlaying")

  @@index([eventId, status])
  @@index([participantId])
}
