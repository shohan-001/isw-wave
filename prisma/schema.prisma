// ISW Wave — Prisma schema (Phase 2)
// Uses the LibSQL driver adapter: a plain local SQLite file in dev, and a
// hosted Turso/LibSQL instance in production (see src/lib/db.ts).
// Modeled with eventId foreign keys everywhere so Phase 5 multi-tenancy does
// not require a rewrite, even though Phase 1 only ever has one Event row.
//
// Phase 2 adds real accounts: a User model, and Request.userId replaces the
// Phase-1 anonymous session id. A logged-in user's request allowance now lives
// in the DB, so it survives cookie/localStorage loss in in-app browsers.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id   String @id @default(cuid())
  name String

  // --- Settings live directly on the Event (feature #3 Settings panel) ---
  requestLimit Int    @default(3) // max pending/queued requests per identified user
  approvalMode String @default("manual") // "manual" | "auto"

  // Which request is currently playing on the admin (audio) player.
  currentRequestId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests Request[] @relation("EventRequests")
  current  Request?  @relation("CurrentlyPlaying", fields: [currentRequestId], references: [id])
}

// Phase 2: real accounts. Password is bcrypt-hashed (see src/lib/auth.ts).
// isAdmin is a boolean role — one admin is seeded manually; a full invite flow
// and granular permissions are deliberately left for later. Kept as a boolean
// (not an enum) per the Phase 2 scope: "one admin role is enough for now".
model User {
  id           String @id @default(cuid())
  username     String @unique
  email        String @unique
  passwordHash String
  isAdmin      Boolean @default(false)

  createdAt DateTime @default(now())

  requests Request[] @relation("UserRequests")
}

model Request {
  id              String @id @default(cuid())
  eventId         String
  youtubeVideoId  String
  title           String
  thumbnailUrl    String
  durationSeconds Int
  channelName     String @default("")

  // Phase 2: the account that made this request. Denormalized requesterName is
  // kept so the display/admin screens can show "requested by X" without a join.
  userId        String
  requesterName String

  // pending | approved | rejected | played
  status String @default("pending")

  // Order within the approved queue. Null unless status = approved.
  queuePosition Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event         Event  @relation("EventRequests", fields: [eventId], references: [id])
  user          User   @relation("UserRequests", fields: [userId], references: [id])
  // Back-relation for Event.current (a request may be the one now playing).
  nowPlayingFor Event? @relation("CurrentlyPlaying")

  @@index([eventId, status])
  @@index([userId])
}
