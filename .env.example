# --- Database (LibSQL / Turso driver adapter) ---
# Local dev: a plain SQLite file. Prisma CLI (migrate/seed) reads this.
DATABASE_URL="file:./prisma/dev.db"

# Production (Vercel): point these at a free Turso instance instead, e.g.
#   TURSO_DATABASE_URL="libsql://<your-db>.turso.io"
#   TURSO_AUTH_TOKEN="<token from `turso db tokens create`>"
# When TURSO_DATABASE_URL is set, src/lib/db.ts uses it; otherwise it falls
# back to the local file above. Vercel's filesystem is ephemeral, so a local
# SQLite file will NOT persist there — use Turso for any real deployment.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# --- YouTube Data API v3 (server-side only, never exposed to the client) ---
# Create a key at https://console.cloud.google.com → enable "YouTube Data API v3".
YOUTUBE_API_KEY=""

# --- Admin dashboard (single shared password for Phase 1) ---
ADMIN_PASSWORD=""

# Secret used to sign session + admin cookies. Use a long random string.
SESSION_SECRET=""

# Public base URL, used to build the QR code target on the Display page.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
