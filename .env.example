# --- Database (LibSQL / Turso driver adapter) ---
# Local dev: a plain SQLite file. Prisma CLI (migrate/seed) reads this.
DATABASE_URL="file:./prisma/dev.db"

# Production (Vercel): point these at a free Turso instance instead, e.g.
#   TURSO_DATABASE_URL="libsql://<your-db>.turso.io"
#   TURSO_AUTH_TOKEN="<token from `turso db tokens create`>"
# When TURSO_DATABASE_URL is set, src/lib/db.ts uses it; otherwise it falls
# back to the local file above. Vercel's filesystem is ephemeral, so a local
# SQLite file will NOT persist there — use Turso for any real deployment.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# --- YouTube Data API v3 (server-side only, never exposed to the client) ---
# Create a key at https://console.cloud.google.com → enable "YouTube Data API v3".
YOUTUBE_API_KEY=""

# Minimum song length (seconds) shown in search — filters out Shorts/teasers.
# Optional; defaults to 60 if unset.
MIN_SONG_SECONDS="60"

# --- Seed admin account (Phase 2) ---
# `npm run db:seed` creates/updates ONE admin User + their Event (with an
# access code). Admins log in via /login → Admin tab. Guests join with
# name + the event access code (no email/password).
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@iswwave.local"
ADMIN_PASSWORD=""

# Secret used to sign the auth cookie (bcrypt handles password hashing).
# Use a long random string.
SESSION_SECRET=""

# Public base URL for the Display QR code (guest join link).
# Local: http://localhost:3000
# Production: https://isw-wave.isharaka.dev
# Do not use *.vercel.app — guests may hit Vercel login / deployment protection.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- Phase 3 realtime (Pusher Channels) ---
# Create a free Channels app at https://pusher.com — optional in local dev
# (the UI falls back to polling when these are unset).
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="mt1"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="mt1"

# --- Owner ops console (hidden; not linked from public UI) ---
# Visit /ops/<OWNER_PANEL_PATH> then enter OWNER_PASSWORD.
# Use a long random path segment (not "owner" or "admin").
OWNER_PANEL_PATH=""
OWNER_PASSWORD=""
